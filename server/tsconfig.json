{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    
    "rootDir": "..", 
    "outDir": "./dist", 

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    
    "paths": {
      "@shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src",
    "../shared/src" 
  ]
}
